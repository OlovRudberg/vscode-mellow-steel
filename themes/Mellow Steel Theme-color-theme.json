	"tokenColors": [
		{
			"name": "Markdown Italic / Emphasis",
			"scope": [
				"emphasis",
				"markup.italic",
			],
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"name": "Markdown Bold & Headings",
			"scope": [
				"strong",
				"markup.heading.markdown",
				"markup.bold.markdown"
			],
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"name": "Markup: Changed",
			"scope": "markup.changed",
			"settings": {
				"foreground": "#000000"
			}
		},
		{
			"name": "Markup: Deletion",
			"scope": "markup.deleted",
			"settings": {
				"foreground": "#000000"
			}
		},
		{
			"name": "Markup: Error",
			"scope": "markup.error",
			"settings": {
				"foreground": "#660000"
			}
		},
		{
			"name": "Markup: Insertion",
			"scope": "markup.inserted",
			"settings": {
				"foreground": "#000000"
			}
		},
		{
			"name": "Markdown Links",
			"scope": [
				"meta.link",
				"meta.link.inline.markdown"
			],
			"settings": {
				"fontStyle": "underline",
				"foreground": "#005cc5"
			}
		},
		{
			"name": "Markup: Output",
			"scope": [
				"markup.output",
				"markup.raw"
			],
			"settings": {
				"foreground": "#777777"
			}
		},
		{
			"name": "Markup: Prompt",
			"scope": "markup.prompt",
			"settings": {
				"foreground": "#777777"
			}
		},
		{
			"name": "Markdown Code Blocks & Inline Code",
			"scope": [
				"markup.fenced_code",
				"markup.inline"
			],
			"settings": {
				"foreground": "#007fff"
			}
		},
		{
			"name": "Markup: Heading",
			"scope": "markup.heading",
			"settings": {
				"foreground": "#AA3731"
			}
		},
		{
			"name": "Markup: Traceback",
